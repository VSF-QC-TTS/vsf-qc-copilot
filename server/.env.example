# Spring
SPRING_PROFILES_ACTIVE=dev
API_PORT=8080

# PostgreSQL (used by docker-compose db service)
POSTGRES_DB=vqc_dev
POSTGRES_USER=vqc
POSTGRES_PASSWORD=vqc

# Database (app connects here; docker-compose overrides to jdbc:postgresql://db:5432/...)
DB_URL=jdbc:postgresql://localhost:5432/vqc_dev
DB_USERNAME=vqc
DB_PASSWORD=vqc

# DB pool
DB_POOL_MAX_SIZE=5
DB_POOL_MIN_IDLE=1

# Security
JWT_SECRET_KEY=change-me-generate-a-random-hex-string
VQC_SECRET_ENCRYPTION_KEY=change-me-64-hex-chars-for-aes256-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URLs
WEB_BASE_URL=http://localhost:5173
SERVER_BASE_URL=http://localhost:8080

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=512

# OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Mail
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@localhost
MAIL_HOST=localhost
MAIL_PORT=1025

# Java
JAVA_TOOL_OPTIONS=-Dfile.encoding=UTF-8 -XX:MaxRAMPercentage=75.0 -XX:InitialRAMPercentage=25.0 -XX:+UseG1GC -XX:+ExitOnOutOfMemoryError
